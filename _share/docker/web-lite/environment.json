{
  "id": "web-lite",
  "name": "Simple static web preview",
  "scope": "shared-template",
  "purpose": "static-web-preview",
  "description": "Serves the project directory with Python http.server through shared Traefik.",
  "composeFile": "docker-compose.yml",
  "dockerfile": "Dockerfile",
  "image": "issue-manager/web-lite:1",
  "defaultInternalPort": 8000,
  "previewUrlTemplate": "http://<project-id>.localhost:8280/",
  "previewTargets": [
    {
      "id": "home",
      "label": "ホーム",
      "urlTemplate": "http://<project-id>.localhost:8280/",
      "kind": "browser",
      "primary": true
    }
  ],
  "shareableAcrossProjects": true,
  "requiresProjectBuild": false,
  "traefik": {
    "enabled": true,
    "network": "traefik",
    "hostTemplate": "<project-id>.localhost",
    "httpPort": 8280,
    "dashboardUrl": "http://localhost:8080/dashboard/"
  },
  "requiredVariables": [
    "COMPOSE_PROJECT_NAME",
    "IM_PROJECT_ID",
    "IM_HOST",
    "IM_PROJECT_DIR"
  ],
  "optionalVariables": [
    "IM_INTERNAL_PORT"
  ],
  "commands": {
    "status": ["compose", "ps", "--format", "json"],
    "start": ["compose", "up", "-d"],
    "stop": ["compose", "down"],
    "restart": ["compose", "restart"],
    "build": ["compose", "build"]
  },
  "safety": {
    "allowBuildButton": true,
    "allowDownVolumes": false,
    "allowPrune": false,
    "volumePolicy": "none"
  },
  "cost": {
    "weight": "light",
    "rebuildUsuallyNeeded": false
  },
  "tags": ["web", "static", "lite", "shared-template"]
}
