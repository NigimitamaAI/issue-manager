{
  "id": "node-lite",
  "name": "Node.js lightweight preview",
  "scope": "shared-template",
  "purpose": "node-web-preview",
  "description": "Runs npm install/npm ci and then npm run dev, npm start, or http-server fallback.",
  "composeFile": "docker-compose.yml",
  "dockerfile": "Dockerfile",
  "image": "issue-manager/node-lite:1",
  "defaultInternalPort": 3000,
  "previewUrlTemplate": "http://<project-id>.localhost:8280/",
  "previewTargets": [
    {
      "id": "home",
      "label": "ホーム",
      "urlTemplate": "http://<project-id>.localhost:8280/",
      "kind": "browser",
      "primary": true
    },
    {
      "id": "health",
      "label": "疎通確認",
      "urlTemplate": "http://<project-id>.localhost:8280/",
      "kind": "healthcheck",
      "expectedStatus": 200
    }
  ],
  "shareableAcrossProjects": true,
  "requiresProjectBuild": false,
  "traefik": {
    "enabled": true,
    "network": "traefik",
    "hostTemplate": "<project-id>.localhost",
    "httpPort": 8280
  },
  "requiredVariables": [
    "COMPOSE_PROJECT_NAME",
    "IM_PROJECT_ID",
    "IM_HOST",
    "IM_PROJECT_DIR"
  ],
  "optionalVariables": [
    "IM_INTERNAL_PORT"
  ],
  "commands": {
    "status": ["compose", "ps", "--format", "json"],
    "start": ["compose", "up", "-d"],
    "stop": ["compose", "down"],
    "restart": ["compose", "restart"],
    "build": ["compose", "build"]
  },
  "safety": {
    "allowBuildButton": true,
    "allowDownVolumes": false,
    "allowPrune": false,
    "volumePolicy": "none"
  },
  "cost": {
    "weight": "light",
    "rebuildUsuallyNeeded": false
  },
  "tags": ["node", "web", "lite", "shared-template"]
}
